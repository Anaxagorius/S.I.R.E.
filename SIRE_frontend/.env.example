# Base URL for API requests to the SIRE backend (no trailing slash)
# The frontend appends /api to this base URL automatically
# Local development default: http://localhost:8080/api
VITE_API_BASE=http://localhost:8080/api

# Optional API key to authenticate requests to the backend
# Must match the API_KEY value configured on the backend
# For local dev the default backend key is: local-dev-key
# Set to empty string or omit if backend has REQUIRE_API_KEY=false
VITE_API_KEY=local-dev-key
